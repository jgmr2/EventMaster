{
  "functions": {
    "index.js": {
      "includeFiles": [
        "node_modules/swagger-ui-dist/**",
        "src/docs/**/*.yaml"
      ]
    }
  },
  "rewrites": [
    {
      "source": "/api-docs/(.*)",
      "destination": "/index.js"
    },
    {
      "source": "/(.*)",
      "destination": "/index.js"
    }
  ]
}